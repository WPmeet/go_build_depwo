rules:
  # ---- Core throughput (Counters only; do rate() in PromQL) ----
  - pattern: 'kafka.server<type=BrokerTopicMetrics, name=(MessagesInPerSec|BytesInPerSec|BytesOutPerSec|TotalProduceRequestsPerSec|TotalFetchRequestsPerSec), topic=(.+)><>Count'
    name: kafka_server_brokertopicmetrics_$1_count
    type: COUNTER
    labels:
      topic: "$2"

  - pattern: 'kafka.server<type=BrokerTopicMetrics, name=(MessagesInPerSec|BytesInPerSec|BytesOutPerSec)><>Count'
    name: kafka_server_brokertopicmetrics_$1_count_alltopics
    type: COUNTER

  # ---- Request mix (no version; Count only) ----
  - pattern: 'kafka.network<type=RequestMetrics, name=RequestsPerSec, request=(.+)><>Count'
    name: kafka_network_requestmetrics_requestspersec_count
    type: COUNTER
    labels:
      request: "$1"

  # ---- Replica / Controller health (small, stable sets) ----
  - pattern: 'kafka.server<type=ReplicaManager, name=(UnderReplicatedPartitions|IsrShrinksPerSec|IsrExpandsPerSec)><>Value'
    name: kafka_server_replicamanager_$1
    type: GAUGE

  - pattern: 'kafka.controller<type=KafkaController, name=(ActiveControllerCount|OfflinePartitionsCount)><>Value'
    name: kafka_controller_kafkacontroller_$1
    type: GAUGE

  # ---- Storage totals (no per-partition) ----
  - pattern: 'kafka.log<type=Log, name=(Size|NumLogSegments), logDirectory=(.+)><>Value'
    name: kafka_log_$1
    type: GAUGE
    labels:
      logDirectory: "$2"

  # ---- Socket: keep only connections; no wildcard; no cache ----
  - pattern: 'kafka.server<type=socket-server-metrics, clientSoftwareName=(.+), clientSoftwareVersion=(.+), listener=(.+), networkProcessor=(.+)><>connections'
    name: kafka_server_socketservermetrics_connections
    type: GAUGE
    labels:
      listener: "$3"
      network_processor: "$4"
    # (intentionally no cache field)

  # ---- Group/Txn coordinators (tiny sets; no cache) ----
  - pattern: 'kafka.coordinator.(\w+)<type=(.+), name=(.+)><>(Count|Value)'
    name: kafka_coordinator_$1_$2_$3
    # no cache

  # ---- Request handler idle percent: use Value (not OneMinuteRate) ----
  - pattern: 'kafka.server<type=KafkaRequestHandlerPool, name=RequestHandlerAvgIdlePercent><>Value'
    name: kafka_server_kafkarequesthandlerpool_requesthandleravgidlepercent
    type: GAUGE

  # =======================
  # Cluster Linking (lean)
  # =======================

  # Manager status (very small; no cache)
  - pattern: 'kafka.server.link<type=ClusterLinkFetcherManager, name=(.+), (.+)=(.+), (.+)=(.+)><>Value'
    name: kafka_server_link_clusterlinkfetchermanager_$1
    labels:
      "$2": "$3"
      "$4": "$5"
    # no cache

  # Link-level metrics: link-name + name (avoid per-broker/fetcher fan-out)
  - pattern: 'kafka.server<type=cluster-link-metrics, link-name=(.+), name=(.+)><>(.+):(.+)'
    name: kafka_server_cluster_link_metrics_$2
    value: $4
    type: GAUGE
    labels:
      link_name: "$1"
    # no cache

  # Fetcher metrics (keep, but no cache; adjust if you want fewer labels)
  - pattern: 'kafka.server<type=cluster-link-fetcher-metrics, (.+)=(.+), (.+)=(.+), (.+)=(.+)><>(.+):'
    name: kafka_server_cluster_link_fetcher_metrics_$7
    type: GAUGE
    labels:
      "$1": "$2"
      "$3": "$4"
      "$5": "$6"
    # no cache
