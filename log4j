log4j:
  # keep what you already have
  - log4j.rootLogger=WARN, stdout
  - log4j.logger.com.splunk=ERROR, stdout
  - log4j.logger.com.splunk.kafka.connect=ERROR, stdout
  - log4j.logger.com.splunk.hecclient=ERROR, stdout
  - log4j.additivity.com.splunk.kafka.connect=false
  - log4j.additivity.com.splunk.hecclient=false

  # only NEW bit: extra appender that drops stack trace and matches the text
  - log4j.appender.backpressure=org.apache.log4j.ConsoleAppender
  - log4j.appender.backpressure.layout=org.apache.log4j.EnhancedPatternLayout
  - log4j.appender.backpressure.layout.ConversionPattern=[%d{ISO8601}] %-5p %c %X{connector.context} - %m %throwable{none}%n
  - log4j.appender.backpressure.filter.1=org.apache.log4j.varia.StringMatchFilter
  - log4j.appender.backpressure.filter.1.StringToMatch=failed to send batch
  - log4j.appender.backpressure.filter.1.AcceptOnMatch=true
  - log4j.appender.backpressure.filter.2=org.apache.log4j.varia.DenyAllFilter

  # and point just the noisy loggers at it
  - log4j.logger.com.splunk.kafka.connect=ERROR, backpressure
  - log4j.logger.com.splunk.hecclient=ERROR, backpressure

# Keep Splunk libraries at ERROR
log4j.logger.com.splunk=ERROR, stdout

# If Splunk sink connector classes are noisy, pin them too
log4j.logger.com.splunk.kafka.connect=ERROR, stdout
log4j.logger.com.splunk.hecclient=ERROR, stdout
log4j.additivity.com.splunk.kafka.connect=false
log4j.additivity.com.splunk.hecclient=false


configOverrides:
    jvm:
      - -Djavax.net.debug=ssl,handshake

    log4j:
      - log4j.rootLogger=INFO, CONSOLE
      - log4j.appender.CONSOLE=org.apache.log4j.ConsoleAppender
      - log4j.appender.CONSOLE.Target=System.out
      - log4j.appender.CONSOLE.layout=org.apache.log4j.PatternLayout
      - log4j.appender.CONSOLE.Threshold=INFO

      # Targeted DEBUG
      - log4j.logger.org.apache.zookeeper=DEBUG
      - log4j.logger.org.apache.zookeeper.server.quorum=DEBUG
      - log4j.logger.org.apache.zookeeper.server.NettyServerCnxnFactory=DEBUG
  blacklist:
    # Per-partition cluster metrics (very high cardinality) — DROP
    - "kafka.cluster:type=Partition,name=InSyncReplicasCount,*"
    - "kafka.cluster:type=Partition,name=LastStableOffsetLag,*"
    - "kafka.cluster:type=Partition,name=ObserversInSyncCount,*"
    - "kafka.cluster:type=Partition,name=ReplicasCount,*"
    - "kafka.cluster:type=Partition,name=UnderMinIsr,*"
    - "kafka.cluster:type=Partition,name=UnderReplicated,*"

    # Per-partition log metrics — DROP
    - "kafka.log:type=Log,name=NumLogSegments,*"
    - "kafka.log:type=Log,name=Size,*"

rules:
  - pattern: kafka.producer<type=producer-topic-metrics, client-id=(.+), topic=(.+)><>record-send-total
    name: kafka_producer_topic_record_send_total
    labels:
      client_id: "$1"
      topic: "$2"
